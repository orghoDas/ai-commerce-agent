# App
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
ADMIN_WEB_URL=http://localhost:3000

# Database
# Docker default:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_commerce_agent
#
# Homebrew PostgreSQL default on macOS usually uses your macOS username:
DATABASE_URL=postgresql://orghodas@localhost:5432/ai_commerce_agent

# OpenAI
# Use deterministic for the no-LLM MVP flow. Switch to openai when billing/quota is ready.
AI_PROVIDER=deterministic
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini

# Auth
SESSION_SECRET=replace_me_with_a_32_char_random_secret
SESSION_TTL_HOURS=12
PASSWORD_RESET_TTL_MINUTES=30
INVITE_TTL_DAYS=7
AUTH_RATE_LIMIT_MAX=8
AUTH_RATE_LIMIT_WINDOW=1 minute
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Uploads
UPLOAD_STORAGE_DIR=uploads
UPLOAD_MAX_BYTES=5000000

# Jobs
REPORT_TIMEZONE_DEFAULT=Asia/Dhaka
DAILY_REPORT_CRON=0 9 * * *

# Billing
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me

# Messaging channels
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
WHATSAPP_VERIFY_TOKEN=replace_me
