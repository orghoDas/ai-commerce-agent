# App
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
ADMIN_WEB_URL=http://localhost:3000

# Database
# Docker default:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_commerce_agent
#
# Homebrew PostgreSQL default on macOS usually uses your macOS username:
DATABASE_URL=postgresql://orghodas@localhost:5432/ai_commerce_agent

# OpenAI
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4.1-mini

# Auth
JWT_SECRET=replace_me_with_long_random_secret

# Jobs
REPORT_TIMEZONE_DEFAULT=Asia/Dhaka
DAILY_REPORT_CRON=0 9 * * *

# Billing
STRIPE_SECRET_KEY=replace_me
STRIPE_WEBHOOK_SECRET=replace_me

# Messaging channels
TWILIO_ACCOUNT_SID=replace_me
TWILIO_AUTH_TOKEN=replace_me
WHATSAPP_VERIFY_TOKEN=replace_me
